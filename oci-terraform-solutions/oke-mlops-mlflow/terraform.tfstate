            "content": "version: 0.1\ncomponent: build\ntimeoutInSeconds: 3600\nshell: bash\nenv:\n  variables:\n    PROJECT_ROOT: \"oci-terraform-solutions/oke-mlops-mlflow\"\n    PACKAGE_DIR: dist\n    PACKAGE_NAME: training_bundle.zip\n    COMPARTMENT_OCID: \"ocid1.compartment.oc1..aaaaaaaakudebt2qkiq7rigx53xbsanwjxzr42tw46ktdmyejwotqsclgo6q\"\n    OCIR_REGION_CODE: \"iad\"\n    OCIR_NAMESPACE: \"idxlfhtrvfsa\"\n    OCIR_REPOSITORY: \"mlflow-training-test\"\n    IMAGE_TAG: \"latest\"\n    OCIR_USERNAME: \"idxlfhtrvfsa/prasanth.prasad@oracle.com\"\n    OCIR_AUTH_TOKEN: \"\"\n    OCIR_AUTH_TOKEN_SECRET_OCID: \"ocid1.vaultsecret.oc1.iad.amaaaaaak6zxdwaayveuyoez3pu6g5vypoewcqs637w53w375oeavdtcccya\"\nsteps:\n  - type: Command\n    name: Install dependencies\n    command: |\n      if [ -d \"${OCI_PRIMARY_SOURCE_DIR}/${PROJECT_ROOT}/training\" ]; then\n        cd \"${OCI_PRIMARY_SOURCE_DIR}/${PROJECT_ROOT}\"\n      elif [ -d \"${OCI_PRIMARY_SOURCE_DIR}/training\" ]; then\n        cd \"${OCI_PRIMARY_SOURCE_DIR}\"\n      else\n        echo \"training/ directory not found from OCI_PRIMARY_SOURCE_DIR=${OCI_PRIMARY_SOURCE_DIR}\"\n        exit 1\n      fi\n      pip3 install --prefer-binary -r training/requirements.txt\n  - type: Command\n    name: Build and push container image to OCIR\n    command: |\n      if [ -d \"${OCI_PRIMARY_SOURCE_DIR}/${PROJECT_ROOT}/training\" ]; then\n        cd \"${OCI_PRIMARY_SOURCE_DIR}/${PROJECT_ROOT}\"\n      else\n        cd \"${OCI_PRIMARY_SOURCE_DIR}\"\n      fi\n      if [ -n \"${OCIR_NAMESPACE}\" ] \u0026\u0026 [ -n \"${OCIR_USERNAME}\" ] \u0026\u0026 [ -n \"${OCIR_AUTH_TOKEN}\" -o -n \"${OCIR_AUTH_TOKEN_SECRET_OCID}\" ]; then\n        bash scripts/build_and_push_ocir_image.sh\n      else\n        echo \"OCIR env vars not fully set (need namespace, username, and token or secret OCID). Skipping container build/push.\"\n      fi\n  - type: Command\n    name: Package training code\n    command: |\n      if [ -d \"${OCI_PRIMARY_SOURCE_DIR}/${PROJECT_ROOT}/training\" ]; then\n        cd \"${OCI_PRIMARY_SOURCE_DIR}/${PROJECT_ROOT}\"\n      else\n        cd \"${OCI_PRIMARY_SOURCE_DIR}\"\n      fi\n      rm -rf ${PACKAGE_DIR}\n      mkdir -p ${PACKAGE_DIR}\n      zip -r ${PACKAGE_DIR}/${PACKAGE_NAME} training scripts\n      ls -lah ${PACKAGE_DIR}\n  - type: Command\n    name: Trigger Data Science Job\n    command: |\n      if [ -d \"${OCI_PRIMARY_SOURCE_DIR}/${PROJECT_ROOT}/training\" ]; then\n        cd \"${OCI_PRIMARY_SOURCE_DIR}/${PROJECT_ROOT}\"\n      elif [ -d \"${OCI_PRIMARY_SOURCE_DIR}/training\" ]; then\n        cd \"${OCI_PRIMARY_SOURCE_DIR}\"\n      else\n        echo \"training/ directory not found from OCI_PRIMARY_SOURCE_DIR=${OCI_PRIMARY_SOURCE_DIR}\"\n        exit 1\n      fi\n      bash scripts/trigger_datascience_job_run.sh\noutputArtifacts:\n  - name: training_bundle\n    type: BINARY\n    location: ${OCI_PRIMARY_SOURCE_DIR}/${PROJECT_ROOT}/${PACKAGE_DIR}/${PACKAGE_NAME}\n",
            "content_base64": null,
            "content_base64sha256": "5oOWcFkYGtWXxN7nQto4jbTLNvk2tuI6l/cc2w8dCPY=",
            "content_base64sha512": "jPfHKzV5DTno2kUK09zqE8eZO+q5LUBXQmmm4cxQlwfK5zeZYQbqrrg6UqIrdWT43CNhDK6A6c4sAAeILgfx0A==",
